# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
APP_URL=http://localhost:3000
INTAKE_TOKEN_SECRET=

# Subdomain zones (single deployment; all three hosts point at this app)
#   marketing → cliniqflow.app      (public site, SEO, legal)
#   app       → app.cliniqflow.app  (workspace, billing, patient intake)
#   auth      → mail.cliniqflow.app (signup, login, onboarding, invites, email links)
# Production defaults are the subdomains below; override for local/staging.
# For local dev on one host, set all three to http://localhost:3000.
NEXT_PUBLIC_ROOT_DOMAIN=cliniqflow.app
NEXT_PUBLIC_MARKETING_URL=https://cliniqflow.app
NEXT_PUBLIC_APP_ORIGIN=https://app.cliniqflow.app
NEXT_PUBLIC_AUTH_ORIGIN=https://mail.cliniqflow.app

# Platform staff (comma-separated, lowercased on read)
PLATFORM_ADMIN_EMAILS=
PLATFORM_SUPPORT_EMAILS=
# Enforce TOTP MFA for platform staff (default: on in production)
PLATFORM_STAFF_MFA_REQUIRED=

# AI — restricted by default; OpenRouter requires BAA vendor in production
AI_PHI_MODE=restricted
AI_BAA_VENDOR=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Rate limiting (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile — CAPTCHA on public intake after repeated submissions
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cron (required in production, min 32 chars)
CRON_SECRET=

# Billing — Razorpay
# PayPal (optional — UI hidden; webhook code kept for future USD/international)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_HOSTED_BUTTON_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=live
PAYPAL_DEFAULT_PLAN=growth

# Razorpay (server secret — never expose KEY_SECRET to the client)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_RAZORPAY_STARTER_PAYMENT_LINK=
NEXT_PUBLIC_RAZORPAY_GROWTH_PAYMENT_LINK=
RAZORPAY_WEBHOOK_SECRET=
# Optional: Razorpay subscription plan IDs (Dashboard → Subscriptions → Plans)
RAZORPAY_STARTER_PLAN_ID=
RAZORPAY_GROWTH_PLAN_ID=
# Optional plan amounts in paise (defaults: starter 3990000, growth 4490000)
RAZORPAY_AMOUNT_STARTER=
RAZORPAY_AMOUNT_GROWTH=

# Email (Zoho SMTP — rotating accounts)
EMAIL_PROVIDER=zoho
ZOHO_ACCOUNTS_JSON=
EMAIL_FROM=CliniqFlow
# Legacy providers (optional)
SENDGRID_API_KEY=
RESEND_API_KEY=

# Observability
SENTRY_DSN=

# Compliance
AUDIT_RETENTION_DAYS=2190
