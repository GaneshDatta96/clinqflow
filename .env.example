# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
APP_URL=http://localhost:3000
INTAKE_TOKEN_SECRET=

# Platform staff (comma-separated, lowercased on read)
PLATFORM_ADMIN_EMAILS=
PLATFORM_SUPPORT_EMAILS=

# AI — restricted by default; OpenRouter requires BAA vendor in production
AI_PHI_MODE=restricted
AI_BAA_VENDOR=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Rate limiting (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron (required in production, min 32 chars)
CRON_SECRET=

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=

# Observability
SENTRY_DSN=

# Compliance
AUDIT_RETENTION_DAYS=2190
